# TMDB API v4 Read Access Token (free).
# Get one at https://www.themoviedb.org/settings/api  ->  "API Read Access Token"
# It is a long JWT-style string starting with "eyJ...".
EXPO_PUBLIC_TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here

# OPTIONAL — only needed where TMDB is blocked (e.g. some ISPs in India).
# Point these at your proxy (see tmdb-proxy-worker.js). Leave unset to use
# TMDB's official domains directly.
# EXPO_PUBLIC_TMDB_API_BASE=https://your-worker.your-subdomain.workers.dev/3
# EXPO_PUBLIC_TMDB_IMAGE_BASE=https://your-worker.your-subdomain.workers.dev/t/p
