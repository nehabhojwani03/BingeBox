# TMDB API v4 Read Access Token (free).
# Get one at https://www.themoviedb.org/settings/api  ->  "API Read Access Token"
# It is a long JWT-style string starting with "eyJ...".
EXPO_PUBLIC_TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here

# OPTIONAL — only needed where TMDB is blocked (e.g. some ISPs in India).
# Point these at your proxy (see tmdb-proxy-worker.js). Leave unset to use
# TMDB's official domains directly.
# EXPO_PUBLIC_TMDB_API_BASE=https://your-worker.your-subdomain.workers.dev/3
# EXPO_PUBLIC_TMDB_IMAGE_BASE=https://your-worker.your-subdomain.workers.dev/t/p

# Supabase (accounts, profiles, sync). Create a project at https://supabase.com,
# then copy Project URL + anon public key from Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Razorpay (subscriptions). Get keys from the Razorpay dashboard (Test mode).
# Only the public Key ID belongs in the app — its presence turns the paywall on.
# The Key Secret and webhook secret are set as Supabase function secrets
# (server-side only), NOT here. RAZORPAY_AMOUNT is the price in paise
# (14900 = ₹149); optional, defaults to 14900:
#   supabase secrets set RAZORPAY_KEY_ID=rzp_test_xxx \
#     RAZORPAY_KEY_SECRET=xxx RAZORPAY_AMOUNT=14900 \
#     RAZORPAY_WEBHOOK_SECRET=xxx
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
